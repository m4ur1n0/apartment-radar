{
  "name": "@apt-radar/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:create": "wrangler d1 create apt_radar",
    "db:migrate:local": "wrangler d1 migrations apply apt_radar --local",
    "db:migrate:remote": "wrangler d1 migrations apply apt_radar --remote"
  },
  "dependencies": {
    "hono": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
